{
  "identifier": "default",
  "description": "Default capabilities for ParseDock",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "shell:default",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "clipboard-manager:default",
    "core:event:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/parsedock-sidecar", "sidecar": true, "args": false },
        { "name": "open", "cmd": "open", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/parsedock-sidecar", "sidecar": true, "args": false },
        { "name": "open", "cmd": "open", "args": true }
      ]
    }
  ]
}
