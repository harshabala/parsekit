{
  "productName": "ParseKit",
  "version": "0.2.4",
  "identifier": "com.harshabala.parsekit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run build:sidecar && npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:sidecar"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ParseKit",
        "width": 320,
        "height": 480,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "center": false,
        "skipTaskbar": true,
        "shadow": true
      },
      {
        "label": "progress-hud",
        "title": "ParseKit Progress",
        "width": 280,
        "height": 120,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "center": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0MTM0NTU4MjE3NjUzMjYKUldRbVUzWWhXRVVUOUR4TndBdGJOTFBUYWlWK0x0eHdyQVZIc2lVbDZtcTMrTDB3cWZtZ2NXdG4K",
      "endpoints": [
        "https://github.com/harshabala/parsekit/releases/latest/download/parsekit-latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["app", "dmg"],
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "../scripts/dmg/dmg-background.png",
        "windowSize": {
          "width": 640,
          "height": 440
        },
        "windowPosition": {
          "x": 200,
          "y": 120
        },
        "appPosition": {
          "x": 155,
          "y": 210
        },
        "applicationFolderPosition": {
          "x": 455,
          "y": 210
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/parsekit-sidecar"],
    "resources": {
      "resources/macos/": "macos/"
    }
  }
}
